        "FTP": ["FTP"],
        "SSH": ["SSH"],
        "SCAN": ["Port Scan", "Stealth Scan", "Horizontal Port Scan", "Slow Port Scan"],
        "DOS": ["DoS", "DDoS", "Flood"],
        "ARP": ["ARP"],
    }
    allow_keywords = mapping.get(DEMO_MODE, [])
    return any(k in attack_type for k in allow_keywords)


