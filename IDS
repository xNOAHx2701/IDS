class LimitedDict(OrderedDict):
    def __init__(self, max_size: int):
        super().__init__()
        self.max_size = max_size

    def __setitem__(self, key, value):
        if len(self) >= self.max_size and key not in self:
            self.popitem(last=False)
        super().__setitem__(key, value)


def validate_ip(ip_str: str) -> bool:
    try:
        ipaddress.ip_address(ip_str)
        return True
    except ValueError:
        return False


def parse_protected_servers(raw: str):
    ips = []
    for part in raw.split(","):
        ip = part.strip()
        if not ip:
            continue
        if validate_ip(ip):
            ips.append(ip)
        else:
            logger.warning(f"Invalid IP ignored: {ip}")
            print(f"Invalid IP ignored: {ip}")
    return set(ips)


def send_email_alert(subject: str, body: str):
    msg = MIMEMultipart()
    msg["From"] = EMAIL_SENDER
    msg["To"] = EMAIL_RECEIVER
    msg["Subject"] = subject
    msg.attach(MIMEText(body, "plain"))

    server = None
    try:
        server = smtplib.SMTP(SMTP_SERVER, SMTP_PORT, timeout=EMAIL_TIMEOUT)
        server.starttls()
        server.login(EMAIL_SENDER, APP_PASSWORD)
        server.sendmail(EMAIL_SENDER, EMAIL_RECEIVER, msg.as_string())
        return True, None
    except Exception as e:
        return False, str(e)
    finally:
        if server is not None:
            try:
                server.quit()
            except Exception:
                pass


_email_queue = queue.Queue(maxsize=EMAIL_MAX_QUEUE)
_last_email_sent = {}
_last_email_lock = Lock()


def _email_worker_loop():
    while True:
        subject, body, attack_type = _email_queue.get()
        try:
            ok, err = send_email_alert(subject, body)
            if ok:
                logger.info(f"Email sent: {attack_type}")
            else:
                logger.error(f"Email failed: {err}")
        except Exception as e:
            logger.error(f"Email worker error: {e}")
        finally:
            _email_queue.task_done()


threading.Thread(target=_email_worker_loop, daemon=True).start()


def _email_key(attack_type: str, entity_key: str) -> str:
    return f"{attack_type}|{entity_key}"


def queue_email(attack_type: str, subject: str, body: str, entity_key: str):
    now = time.time()
    key = _email_key(attack_type, entity_key)
    with _last_email_lock:
        last = _last_email_sent.get(key, 0)
        if now - last < EMAIL_COOLDOWN_SECONDS:
            return
        _last_email_sent[key] = now

    try:
        _email_queue.put_nowait((subject, body, attack_type))
    except queue.Full:
        logger.error("Email queue full, dropping email")


